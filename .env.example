# Shared
ENV=development
APP_NAME=Civic Pulse
REGION_LABEL=Bengaluru
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000
NEXT_DIST_DIR=.next-dev
NEXT_PUBLIC_ENABLE_PWA=false
WEB_RUNTIME_MODE=dev-hot-reload
APP_BUILD_STAMP=local
DOMAIN=localhost
TLS_EMAIL=ops@example.org

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=civic
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic
DATABASE_URL=postgresql+psycopg://civic:civic@postgres:5432/civic
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60

# Redis
REDIS_URL=redis://redis:6379/0
WORKER_QUEUES=classification
WORKER_WITH_SCHEDULER=false

# MinIO (S3 compatible)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=civic-raw
S3_BUCKET_PUBLIC=civic-public
S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# Classification policy
AI_CONFIDENCE_THRESHOLD=0.72
AI_PREVIEW_TIMEOUT_SECONDS=8
AI_CIRCUIT_FAILURES_BEFORE_OPEN=5
AI_CIRCUIT_OPEN_SECONDS=30
GEOCODE_TIMEOUT_SECONDS=3.5
GEOCODE_CACHE_TTL_SECONDS=1800
GEOCODE_CIRCUIT_FAILURES_BEFORE_OPEN=5
GEOCODE_CIRCUIT_OPEN_SECONDS=20
PUBLIC_LOCATION_JITTER_METERS=75
MEDIA_RETENTION_DAYS=180

# Abuse controls
ANON_DEVICE_DAILY_LIMIT=5
ANON_IP_DAILY_LIMIT=20
DUPLICATE_COOLDOWN_MINUTES=10
CAPTURE_MAX_AGE_MINUTES=10
PRIORITY_WEIGHT_SEVERITY=0.4
PRIORITY_WEIGHT_AGE=0.25
PRIORITY_WEIGHT_DUPLICATE_DENSITY=0.2
PRIORITY_WEIGHT_SAFETY_FLAG=0.15

# Firebase Authentication
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_CREDENTIALS_PATH=
ALLOW_TEST_OTP=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Admin
ADMIN_API_KEY=

# Notification delivery
NOTIFY_FROM_NAME=Civic Pulse
NOTIFY_FROM_EMAIL=noreply@example.org
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_FROM_NUMBER=
